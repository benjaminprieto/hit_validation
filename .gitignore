05_results/

# =============================================================================
# Logs and stdout captures
# =============================================================================
logs/
*.log
nohup.out
!check_dependencies.sh

# =============================================================================
# Python build artifacts
# =============================================================================
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
*.egg
.pytest_cache/
.coverage
.tox/
.mypy_cache/
.ruff_cache/

# =============================================================================
# Editor / IDE
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~

# =============================================================================
# OS
# =============================================================================
.DS_Store
Thumbs.db

# =============================================================================
# DOCK6 temporary files
# =============================================================================
OUTSPH
temp*
*.dms
*.sph
*.box
grid.nrg
grid.bmp

# =============================================================================
# AmberTools / antechamber temporary files
# =============================================================================
ANTECHAMBER_*
ATOMTYPE.INF
sqm.in
sqm.out
sqm.pdb
leap.log
mdinfo
mdvel
mdfrc

# =============================================================================
# MD / topology / per-frame artifacts (defense-in-depth: these live inside
# 05_results/ which is already ignored, but prevent accidental tracking if
# anyone runs scripts at the project root).
# =============================================================================
*.dcd
*.mdcrd
*.prmtop
*.inpcrd
*.rst7
*.parm7
*.nc
_MMPBSA_*

# =============================================================================
# Local backups (manual or scripted before refactors)
# =============================================================================
*_backup_*/
*.original

# =============================================================================
# Secrets / local environment overrides (defense in depth)
# =============================================================================
.env
.env.local
*.key
*.pem
*.secret
# Backup files
*.bak
